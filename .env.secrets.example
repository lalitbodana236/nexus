# Shared runtime values for both dev and prod compose files.
# Copy this to `.env.secrets` and fill in real values.

POSTGRES_DB=nexus_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DB_URL=jdbc:postgresql://postgres:5432/nexus_db
DB_USERNAME=postgres
DB_PASSWORD=postgres

GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

APP_CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1
APP_FRONTEND_SUCCESS_URL=http://localhost/auth/callback?login=success
APP_FRONTEND_FAILURE_URL=http://localhost/login?error=oauth
APP_SECURITY_ADMIN_EMAILS=admin@example.com
APP_SECURITY_REQUIRE_SSL=false
SERVER_SERVLET_SESSION_COOKIE_SECURE=false
SERVER_SERVLET_SESSION_COOKIE_SAME_SITE=lax
